VLLM_IMAGE=intel/vllm
VLLM_IMAGE_TAG=0.21.0-ubuntu24.04
VLLM_CONTAINER_NAME=vllm-server
VLLM_SHM_SIZE=4g

# PATH to checkpoint directory on the host machine for fine-tuning
FINE_TUNING_HOST_PATH=/path/to/checkpoint/directory/

# PATH to LoRA adapter checkpoint directory mounted inside container. 
# This is the path where the LoRA adapter checkpoint is stored inside the container.    
VLLM_LORA_ADAPTER_PATH=/path/to/checkpoint/directory/qwen_3.5_2b_adapter/checkpoint-432/

DRI_MOUNT_PATH=/dev/dri

# Runtime
VLLM_WORKER_MULTIPROC_METHOD=spawn
VLLM_MODEL_NAME=unsloth/Qwen3.5-2B
VLLM_SERVED_MODEL_NAME=unsloth/Qwen3.5-2B
VLLM_DTYPE=float16
VLLM_PORT=8000
VLLM_BLOCK_SIZE=64
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_MAX_MODEL_LEN=8192
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_QUANTIZATION=fp8

# LoRA adapter
VLLM_LORA_ADAPTER_NAME=qwen3.5-2b-adapter

