-    ov_config = OVConfig(model_dir="/tmp/model", device="CPU")
+    ov_config = OVConfig(model_dir=tmp_model_dir, device="CPU")
     mock_compiled_model, mock_infer_request = setup_mock_ov(
         mock_openvino, 
         ["images", "img_masks", "lang_tokens", "lang_masks", "noise", "prev_chunk_left_over", "prefix_weights"]
