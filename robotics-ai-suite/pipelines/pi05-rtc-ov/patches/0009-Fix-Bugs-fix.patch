+    ov_config = OVConfig(model_dir=tmp_model_dir, device="CPU")
     mock_compiled_model, mock_infer_request = setup_mock_ov(
         mock_openvino, ["images", "img_masks", "lang_tokens", "lang_masks", "noise"]
     )
@@ -137,9 +141,9 @@ def test_predict_action_chunk_ov_non_rtc_model(mock_openvino, pi05_config):
     
     assert actions.shape == (batch_size, pi05_config.chunk_size, pi05_config.output_features[ACTION].shape[0])
 
-def test_predict_action_chunk_ov_rtc_model_with_params(mock_openvino, pi05_config):
