+def keyboard_listener(
+    execution_paused_event: Event,
+    rtc_enabled_ref: list,
+    rtc_config,
+    keyboard_shutdown_event: Event,
+    episode_started_ref: list,
+):
+    """
+    Keyboard controls (requires a TTY):
+      Space  - start / pause / resume action_control
+      r / R  - toggle rtc_enabled on/off
+
+    keyboard_shutdown_event: set only when the whole process exits (not between episodes)
+    episode_started_ref:     [bool] reset to False at the start of each episode by main()
+    """
+    if not sys.stdin.isatty():
+        logger.warning("[KEYBOARD] stdin is not a TTY, keyboard control disabled.")
+        return
+
+    fd = sys.stdin.fileno()
+    old_settings = termios.tcgetattr(fd)
+    logger.info("[KEYBOARD] Controls: [Space] Start/Pause/Resume  [r] Toggle RTC")
+    try:
+        tty.setcbreak(fd)
+        while not keyboard_shutdown_event.is_set():
+            ready, _, _ = select.select([sys.stdin], [], [], 0.1)
+            if not ready:
+                continue
+            ch = sys.stdin.read(1)
+            if ch == ' ':
+                if execution_paused_event.is_set():
+                    execution_paused_event.clear()
+                    if not episode_started_ref[0]:
+                        episode_started_ref[0] = True
+                        logger.info("[KEYBOARD] Execution started")
+                    else:
+                        logger.info("[KEYBOARD] Resumed action control")
+                else:
+                    execution_paused_event.set()
+                    logger.info("[KEYBOARD] Paused action control")
+            elif ch in ('r', 'R'):
+                new_val = not rtc_enabled_ref[0]
+                rtc_enabled_ref[0] = new_val
+                # Must also update rtc_config so ActionQueue.merge() switches mode
+                rtc_config.enabled = new_val
+                state_str = "ENABLED" if new_val else "DISABLED"
+                logger.info(f"[KEYBOARD] RTC {state_str}")
+    except Exception as e:
+        logger.error(f"[KEYBOARD] Error: {e}")
+    finally:
+        try:
+            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
+        except Exception:
+            pass
