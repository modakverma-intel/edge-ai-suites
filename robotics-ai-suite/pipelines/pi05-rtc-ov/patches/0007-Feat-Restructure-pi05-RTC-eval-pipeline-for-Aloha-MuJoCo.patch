+class _VizProcess:
+    """Visualization in a child process. Main writes the latest BGR frame to a
+    shared-memory buffer; the child reads it and calls cv2.imshow + waitKey,
+    completely off the main process's GIL/event loop."""
+
+    def __init__(self, height: int, width: int):
+        from multiprocessing import Process, Event as MPEvent
+        from multiprocessing.shared_memory import SharedMemory
+        self._h = height
+        self._w = width
+        self._shape = (height, width, 3)
+        self._dtype = np.uint8
+        self._nbytes = int(np.prod(self._shape)) * np.dtype(self._dtype).itemsize
+        self._shm = SharedMemory(create=True, size=self._nbytes + 8)
+        # First 8 bytes: uint64 frame counter; rest: image data.
+        shm_buf = self._shm.buf
+        assert shm_buf is not None
+        self._counter = np.ndarray((1,), dtype=np.uint64, buffer=shm_buf[:8])
+        self._counter[0] = 0
+        self._frame = np.ndarray(self._shape, dtype=self._dtype, buffer=shm_buf[8:])
+        self._stop = MPEvent()
+        self._proc = Process(
+            target=_viz_child_main,
+            args=(self._shm.name, self._shape, self._stop),
+            daemon=True,
+        )
+        self._proc.start()
+
+    def write(self, rgb_img: np.ndarray) -> None:
+        # Convert RGB → BGR for cv2; copy into shm and bump counter atomically-enough
+        # (single writer, single reader using counter as monotonic newness flag).
+        if rgb_img.shape != self._shape:
+            import cv2
+            rgb_img = cv2.resize(rgb_img, (self._w, self._h))
+        if rgb_img.strides[0] < 0 or rgb_img.strides[1] < 0:
+            rgb_img = rgb_img.copy()
+        self._frame[:] = rgb_img[..., ::-1]  # RGB → BGR
+        self._counter[0] = self._counter[0] + 1
+
+    def close(self) -> None:
+        self._stop.set()
+        try:
+            self._proc.join(timeout=2.0)
+        except Exception:
+            pass
+        try:
+            self._shm.close()
+            self._shm.unlink()
+        except Exception:
+            pass
+
+
+def _viz_child_main(shm_name: str, shape: tuple, stop_event) -> None:
+    """Runs in the child process — owns the cv2 window, no GIL contention with main."""
+    import cv2
+    from multiprocessing.shared_memory import SharedMemory
+    shm = SharedMemory(name=shm_name)
+    shm_buf = shm.buf
+    assert shm_buf is not None
+    counter = np.ndarray((1,), dtype=np.uint64, buffer=shm_buf[:8])
+    frame = np.ndarray(shape, dtype=np.uint8, buffer=shm_buf[8:])
+    win = "aloha_eval"
+    cv2.namedWindow(win, cv2.WINDOW_NORMAL)
+    cv2.resizeWindow(win, shape[1], shape[0])
+    last_seen = -1
+    while not stop_event.is_set():
+        cur = int(counter[0])
+        if cur != last_seen:
+            cv2.imshow(win, frame)
+            last_seen = cur
+        # waitKey processes GUI events; 16ms ≈ 60Hz event polling
+        cv2.waitKey(16)
+    try:
+        cv2.destroyAllWindows()
+    except Exception:
+        pass
+    shm.close()
+
+
+def _start_viz_process(plot_enabled: bool, height: int, width: int):
+    if not plot_enabled:
+        return None
+    try:
+        return _VizProcess(height=height, width=width)
+    except Exception as e:
+        logger.warning(f"Failed to start viz process, disabling --plot: {e}")
+        return None
+
